```mermaid
classDiagram
  class Owner {
    +String name
    +String work_schedule
    +int available_hours
    +String preferred_morning_start
    +String preferred_evening_end
    +get_name()
    +get_availability()
    +set_availability()
  }

  class Pet {
    +String name
    +String species
    +String gender
    +int age
    +String health_history
    +String medical_needs
    +Owner owner
    +List tasks
    +get_name()
    +get_species()
    +get_age()
    +get_medical_needs()
    +add_task()
    +get_tasks()
  }

  class Task {
    +String name
    +int duration
    +int priority
    +String type
    +String scheduled_time
    +bool is_completed
    +get_name()
    +get_duration()
    +get_priority()
    +get_type()
    +set_priority()
    +mark_complete()
  }

  class Schedule {
    +Owner owner
    +List pets
    +List tasks
    +List generated_plan
    +String reasoning
    +generate_plan()
    +explain_reasoning()
    +display_plan()
  }

  Owner "1" --> "1..*" Pet : owns
  Pet "1" --> "0..*" Task : has
  Schedule "1" --> "1" Owner : uses
  Schedule "1" --> "1..*" Pet : schedules for
  Schedule "1" --> "0..*" Task : organizes
```